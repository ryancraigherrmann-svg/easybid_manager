{
  "name": "easybid-backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p .",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:inspect": "ts-node src/debug/prismaCheck.ts",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "ts-node ./prisma/seed.ts",
    "seed:e2e": "ts-node src/seed-e2e.ts",
    "seed:e2e:force": "ts-node src/seed-e2e.ts --force"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.2.0",
    "apollo-server-express": "^3.11.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "graphql": "^16.7.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.2",
    "pg": "^8.13.0",
    "prisma": "^7.2.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.2",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.11.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts",
    "schema": "schema.prisma"
  }
}
