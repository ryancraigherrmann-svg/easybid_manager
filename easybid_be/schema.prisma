generator client {
  provider = "prisma-client-js"
  output   = "./src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Bid {
  id           Int           @id @default(autoincrement())
  amount       Float
  approved     Boolean       @default(false)
  user         String?
  company      String?
  info         String?
  expectedDate DateTime?
  rfpId        Int?
  rfp          RFP?          @relation(fields: [rfpId], references: [id])
  postings     BidPosting[]
  lineItems    BidLineItem[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model BidPosting {
  id            Int      @id @default(autoincrement())
  bidId         Int
  description   String?
  type          String?
  images        Json?
  attributes    Json?
  selectedOffer Int?
  company       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  bid           Bid      @relation(fields: [bidId], references: [id])
}

model RFP {
  id              Int         @id @default(autoincrement())
  currentBids     Int?
  description     String?
  jobType         String?
  images          Json?
  attributes      Json?
  originalCompany String?
  status          Int?        @default(1)
  startDate       DateTime?
  bidsDueDate     DateTime?
  // Optional email list stored directly on the RFP
  emailList       String[]    @default([])
  // Optional relation to an EmailGroup
  emailGroupId    Int?
  emailGroup      EmailGroup? @relation(fields: [emailGroupId], references: [id])
  title           String?
  User            String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  jobs            Job[]
  bids            Bid[]
}

model EmailGroup {
  id        Int      @id @default(autoincrement())
  name      String
  company   String?
  emails    String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rfps      RFP[]
}

model Job {
  id           Int      @id @default(autoincrement())
  title        String?
  description  String
  rfpId        Int?
  rfp          RFP?     @relation(fields: [rfpId], references: [id])
  jobType      String
  startDate    String
  daysExpected Int
  company      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BidLineItem {
  id          Int      @id @default(autoincrement())
  bidId       Int
  description String?
  amount      Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bid         Bid      @relation(fields: [bidId], references: [id])
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  firstName    String?
  lastName     String?
  companyId    Int?
  company      Company? @relation(fields: [companyId], references: [id])
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Company {
  id         Int      @id @default(autoincrement())
  name       String?
  type       String?
  typeOfWork String?
  users      User[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CompanyFinancial {
  id      Int @id @default(autoincrement())
  routing Int
  account Int
}
