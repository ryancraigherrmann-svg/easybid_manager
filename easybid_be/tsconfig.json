{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
    },
  "exclude": [
    "prisma.config.ts",
    "prisma.config.js",
    "prisma.config.cjs",
    "node_modules"
  ]
}
